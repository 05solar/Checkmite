NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://checkmite:password@127.0.0.1:5432/checkmite

UPLOAD_DIR=uploads
UPLOAD_MAX_IMAGE_MB=20
UPLOAD_MAX_VIDEO_MB=500

MODEL_RUNTIME_URL=http://127.0.0.1:8000
MODEL_RUNTIME_REQUIRED=false
FRONTEND_DIST_DIR=dist

CHECKMITE_MODEL_PATH=./model/best.pt
CHECKMITE_CONF=0.5
CHECKMITE_IMGSZ=640
CHECKMITE_TILE_SIZE=640
CHECKMITE_TILE_OVERLAP=0.5
CHECKMITE_NMS_IOU=0.3
CHECKMITE_VITALITY_TARGET_CLASS=predator
CHECKMITE_VITALITY_PX_PER_MM=1500
CHECKMITE_VITALITY_REFERENCE_SPEED_MM_SEC=0.15
CHECKMITE_VITALITY_MIN_TRACK_FRAMES=3
CHECKMITE_VITALITY_MOTION_THRESHOLD_PX=2.0
CHECKMITE_VITALITY_MAX_FRAMES=0
